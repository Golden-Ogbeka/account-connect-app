{
  "name": "account-connect-app-server",
  "version": "1.0.0",
  "description": "Account Connect App - GraphQL API Server",
  "license": "ISC",
  "author": "Golden Ogbeka",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "type:check": "tsc --noEmit",
    "compile": "tsc",
    "start": "npm run compile && node ./dist/index.js",
    "dev": "nodemon",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "jest",
    "prepare": "husky"
  },
  "dependencies": {
    "@apollo/server": "^4.13.0",
    "@databases/sqlite": "^4.0.2",
    "colors": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "graphql": "^16.13.2",
    "graphql-tag": "^2.12.6",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "uuid": "^10.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/colors": "^1.1.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.5",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^13.2.3",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
